# <-- Target Images -->
CONFIG_TARGET_bcm27xx=y
CONFIG_TARGET_bcm27xx_bcm2710=y
CONFIG_TARGET_bcm27xx_bcm2710_DEVICE_rpi-3=y
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=472

# <-- Administration -->
CONFIG_PACKAGE_btop=y
CONFIG_PACKAGE_htop=y

# <-- Extra packages -->
# CONFIG_PACKAGE_automount is not set

# <-- Kernel modules -->
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y
CONFIG_PACKAGE_kmod-usb-net-rtl8150=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152-vendor=y

# <-- LuCI -->
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-cifs-mount=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y

# <-- Network -->
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_rclone-config=y
CONFIG_PACKAGE_ss=y
CONFIG_PACKAGE_git-http=y
CONFIG_PACKAGE_proto-bonding=y
CONFIG_PACKAGE_tcpdump=y

# <-- Utilities -->
CONFIG_PACKAGE_vim-fuller=y
CONFIG_PACKAGE_zsh=y
CONFIG_PACKAGE_dockerd=y
# CONFIG_DOCKER_CGROUP_OPTIONS is not set
CONFIG_PACKAGE_lm-sensors-detect=y
CONFIG_PACKAGE_lscpu=y
CONFIG_PACKAGE_lsof=y
CONFIG_PACKAGE_shadow-utils=y
